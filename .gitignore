# Build artifacts
[Bb]in/
[Oo]bj/
[Oo]ut/
[Pp]ublish/
artifacts/
*.user
*.suo
.vs/
.vscode/launch.json

# Test results & coverage
TestResults/
coverage/
*.coverage
*.coveragexml
*.trx

# Generated SDL artifacts (regenerated via tools/Packet.Sdl.CodeGen)
# We DO check generated *.g.cs in (so reviewers can diff against YAML).
# Don't ignore them.

# Tooling caches
.idea/
*.swp
.DS_Store
.claude/

# Stryker reports + scratch
artifacts/
StrykerOutput/

# Local node state (used when running the node out of the repo)
.local/
node-data/
*.db
*.db-shm
*.db-wal

# Frontend
web/packetnet-ui/node_modules/
web/packetnet-ui/dist/
web/packetnet-ui/.vite/
web/packetnet-ui/.turbo/
web/packetnet-ui/pnpm-lock.yaml.bak

# Docker
docker/.build-cache/

# LinBPQ runtime artifacts (extracted by the container at startup, not source)
docker/linbpq/HTML/
docker/linbpq/BPQNODES.dat
docker/linbpq/MHSave.txt
docker/linbpq/logs/
docker/linbpq/*.log

# Secrets — never commit
*.pem
!installers/sigstore-pubkey.pem
*.pfx
appsettings.Local.json
appsettings.*.user.json

# Per-developer launch configuration (port choices, env vars)
**/Properties/launchSettings.json

# OS
Thumbs.db
ehthumbs.db

# TypeScript build artefacts for the ax25 web library
web/ax25/dist/

# Packet.Ax25.Sdl moved to m0lte/ax25sdl on 2026-05-17 — consumed via
# NuGet now. The local SDL codegen tools (still in tools/Packet.Sdl.*)
# would regenerate the deleted directory if run with --csharp; ignore
# the output so a stray invocation doesn't leave untracked artefacts in
# the working tree. C# codegen now lives in m0lte/ax25sdl.
src/Packet.Ax25.Sdl/
